---
import Layout from "../layouts/Layout.astro";
---

<Layout>

    <section class="success">

        <div class="container">

            <span class="success__subtitle">
                Pengajuan Berhasil Dikirim
            </span>

            <h1 class="success__main-title">

                Terima Kasih

                <span class="success__main-title-italic">
                    Atas Pengajuan Anda
                </span>

            </h1>

            <p class="success__text">
                Pengajuan Anda telah berhasil kami terima.
            </p>

            <p class="success__text">
                Tim kami akan meninjau pengajuan Anda dan menghubungi Anda apabila diperlukan informasi tambahan.
            </p>

        </div>

    </section>

</Layout>

<style>

    .success {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8rem 0;
        background-color: #f2f1ee;
    }

    .success .container {
        max-width: 80rem;
        text-align: center;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .success__subtitle {
        display: inline-flex;
        align-items: center;
        color: #111; 
        font-size: 1.2rem; 
        font-weight: 400;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
        margin-bottom: 3.2rem;
    }

    .success__subtitle::before {
        content: ""; 
        display: inline-block;
        width: 0.6rem; 
        height: 0.6rem; 
        background-color: #111;
        border-radius: 50%; 
        margin-right: 1rem; 
    }

    .success__main-title {
        display: flex;
        flex-direction: column;
        color: #111;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        max-width: 60rem;
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
        margin-bottom: 3.2rem;
    }

    .success__main-title-italic {
        font-style: italic;
        color: #888;
    }

    .success__text {
        color: #888;
        font-size: 1.6rem;
        line-height: 1.7;
        max-width: 60rem;
        margin: 0 auto;
    }

    @media (max-width: 768px) {

        .success {
            min-height: 60vh;
            padding: 5rem 0;
        }

        .success__title {
            font-size: 3.2rem;
        }

        .success__text {
            font-size: 1.4rem;
        }

    }

</style>