        </div>

        <p class="jury-members__note">
            All communication with jury members is conducted exclusively through official Woodara channels.
        </p>

    </div>

</section>

<style>

    .jury2 {
        background-color: #f2f1ee;
        padding: 8rem 0;
    }

    .jury2 .container {
        width: 100%;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
    }

    /* heading */
    .jury2__heading {
        max-width: 66rem;
        margin-bottom: 8rem;
    }

    .jury2__subtitle {
        display: inline-flex;
        align-items: center;
        color: #111; 
        font-size: 1.2rem; 
        font-weight: 400;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
        margin-bottom: 3.2rem;
    }

    .jury2__subtitle::before {
        content: ""; 
        display: inline-block;
        width: 0.6rem; 
        height: 0.6rem; 
        background-color: #111;
        border-radius: 50%; 
        margin-right: 1rem;
    }

    .jury2__title {
        display: flex;
        flex-direction: column;
        color: #111;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
        margin-bottom: 2rem;
    }

    .jury2__title-secondary {
        font-style: italic;
        color: #888;
        font-weight: 300;
    }

    .jury2__description {
        max-width: 66rem;
        color: #888;
        font-size: 1.6rem;
        line-height: 1.7;
    }

    /* members */

    .jury2__list {
        display: flex;
        flex-direction: column;
        gap: 6rem;
    }

    .jury-member {
        display: grid;
        grid-template-columns: 21rem 1fr;
        gap: 3rem;
        align-items: start;
    }

    .jury-member__image {
        width: 21rem;
        aspect-ratio: 1 / 1;
        overflow: hidden;
    }

    .jury-member__image-item {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .jury-member__content {
        max-width: 70rem;
    }

    .jury-member__name {
        color: #111;
        font-size: 2.4rem;
        font-weight: 300;
        line-height: 1;
        margin-bottom: 1rem;
    }

    .jury-member__role {
        color: #888;
        font-size: 1.6rem;
        line-height: 1.5;
        margin-bottom: 2.4rem;
    }

    .jury-member__company {
        display: inline-block;
        color: #111;
        font-size: 1.2rem;
        letter-spacing: 0.24rem;
        text-transform: uppercase;
        margin-bottom: 2.8rem;
    }

    .jury-member__text {
        color: #888;
        line-height: 1.7;
        margin-bottom: 1.4rem;
    }

    .jury-member__quote {
        color: #888;
        line-height: 1.7;
        font-style: normal;
    }

    .jury-members__note {
        margin-top: 6rem;
        color: #111;
        font-size: 1.4rem;
    }

    /* mobile */

@media (max-width: 768px) {

    .jury2 {
        padding: 5rem 0;
    }

    .jury2__heading {
        margin-bottom: 5rem;
    }

    .jury2__subtitle {
        margin-bottom: 2rem;
    }

    .jury2__title {
        font-size: 3.2rem;
        margin-bottom: 2rem;
    }

    .jury2__description {
        font-size: 1.4rem;
    }

    .jury2__list {
        gap: 5rem;
    }

    .jury-member {
        grid-template-columns: 1fr;
        gap: 3rem;
    }

    .jury-member__image {
        width: 100%;
        max-width: 18rem;
    }

    .jury-member__name {
        font-size: 2.8rem;
    }

    .jury-member__role {
        margin-bottom: 1.6rem;
    }

    .jury-member__company {
        margin-bottom: 2rem;
    }

    .jury-members__note {
        margin-top: 5rem;
        font-size: 1.3rem;
    }
}

</style>