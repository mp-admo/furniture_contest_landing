<section class="jury2">

    <div class="container">

        <div class="jury2__heading">

            <span class="jury2__subtitle">
                International Jury
            </span>

            <h3 class="jury2__title">

                Meet The Experts

                <span class="jury2__title-secondary">
                    Behind The Competition
                </span>

            </h3>

            <p class="jury2__description">
                An international panel of designers, educators, manufacturers and industry professionals will evaluate submissions based on creativity, feasibility, market potential and cultural relevance.
            </p>

        </div>

        <div class="jury2__list">

            <!-- juri memmber 1 -->
            <article class="jury-member">

                <div class="jury-member__image">

                    <img
                        src="/juri_member_01.jpg"
                        alt="International Jury Member"
                        class="jury-member__image-item"
                    >

                </div>

                <div class="jury-member__content">

                    <h4 class="jury-member__name">
                        Name Coming Soon
                    </h4>

                    <p class="jury-member__role">
                        International Jury Member
                    </p>

                    <span class="jury-member__company">
                        PINTO • FRANCE
                    </span>

                    <p class="jury-member__text">
                        Representative of one of France's leading luxury interior and furniture design companies, specializing in bespoke furniture, architecture and high-end hospitality projects worldwide.
                    </p>

                    <blockquote class="jury-member__quote">
                        “We are looking for original ideas that combine strong cultural identity with international design standards.”
                    </blockquote>

                </div>

            </article>

            <!-- juri memmber 2 -->
            <article class="jury-member">

                <div class="jury-member__image">

