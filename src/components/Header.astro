<style>
    /* Шапка */
    .header {
        display: flex;
        align-items: center; 
        background-color: #f9f9f9;
        height: 6.4rem;
        width: 100%;
        z-index: 100;
        border-bottom: 0.1rem solid rgba(131, 131, 131, 0.1);
        position: sticky;
        top: 0;
    }

    .header__nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
        height: 100%;  
        width: 100%;
    }

   .header__menu {
        display: flex;
        gap: 4rem;
        margin: 0 auto;
    }

    .header__logo-image {
        height: 2rem;
        width: auto;
        display: block;
    }

    .header__pill {
        display: inline-flex;
        align-items: center;
        gap: 1rem;                  
        background-color: #f9f9f9;
        color: #888;
        padding: 1rem 1.6rem;      
        border-radius: 10rem;
        border: 1px solid #bdbdbd;       
        font-size: 1.2rem;          
        font-weight: 500;
        line-height: 1;
        letter-spacing: 0.2rem;
        text-decoration: none;
        text-transform: uppercase;
    }

    .header__flag {
        width: 1.6rem;
        height: 1.6rem;
        object-fit: cover;
        flex-shrink: 0;
    }

    .header__text-mobile {
        display: none;
    }

    .header__menu-link {
        color: #888;
        line-height: 1;
        letter-spacing: -0.01em;
        font-weight: 500;
        text-decoration: none;
        transition: color .3s ease;
    }

    .header__menu-link:hover {
        color: #111;
    }

    .burger-button {
        display: none;
    }

    .mobile-menu {
        position: fixed;
        top: 6.4rem;
        left: 0;
        width: 100%;
        height: calc(100vh - 6.4rem);
        background-color: #f9f9f9;
        padding: 5rem 2rem;
        display: flex;
        flex-direction: column;
        opacity: 0;
        visibility: hidden;
        transition: .3s ease;
        z-index: 200;
    }

    .mobile-menu.is-open {
        opacity: 1;
        visibility: visible;
    }

    .mobile-menu__pill {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        align-self: flex-start;
        padding: 1rem 1.6rem;
        border: 1px solid #bdbdbd;
        border-radius: 10rem;
        color: #888;
        font-size: 1.2rem;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
        margin-bottom: 5rem;
    }

    .mobile-menu__flag {
        width: 1.6rem;
        height: 1.6rem;
    }

    .mobile-menu__nav {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        margin-bottom: 10rem;
    }

    .mobile-menu__nav a {
        color: #111;
        text-decoration: none;
        font-size: 1.8rem;
        font-weight: 400;
        line-height: 1;
    }

    .mobile-menu__socials {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        margin-bottom: 10rem;
    }

    .mobile-menu__socials a {
        color: #111;
        text-decoration: none;
        font-size: 2rem;
        font-weight: 400;
        line-height: 1;
    }

    .mobile-menu__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        align-self: flex-start;
        padding: 1.8rem 3rem;
        border-radius: 10rem;
        background-color: #ff4b00;
        color: #fff;
        text-decoration: none;
        font-size: 1.8rem;
    }

    @media (max-width: 768px) {

        .header__menu {
            display: none;
        }

        .header__logo-image {
            height: 1.3rem;
        }

        .header__pill {
            padding: 0.8rem 1.2rem;
            font-size: 1rem;
            white-space: nowrap;
        }

        .header__flag {
            width: 1.4rem;
            height: 1.4rem;
        }

        .header__text-desktop {
            display: none;
        }

        .header__text-mobile {
            display: inline;
        }

        .header__pill {
            display: none;
        }

        .burger-button {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 0.4rem;
            background: transparent;
            border: none;
            cursor: pointer;
            width: 2.4rem;
            height: 2.4rem;
            padding: 0;
        }

        .burger-button span {
            width: 100%;
            height: 0.2rem;
            background-color: #111;
            transition: .3s ease;
        }

        .burger-button--active span:nth-child(1) {
            transform: translateY(0.6rem) rotate(45deg);
        }

        .burger-button--active span:nth-child(2) {
            opacity: 0;
        }

        .burger-button--active span:nth-child(3) {
            transform: translateY(-0.6rem) rotate(-45deg);
        }

    }
   
</style>


<script>

    const burgerBtn = document.querySelector('.burger-button');
    const mobileMenu = document.querySelector('.mobile-menu');
    const menuLinks = document.querySelectorAll('.mobile-menu__nav a');

    if (burgerBtn && mobileMenu) {

        burgerBtn.addEventListener('click', () => {

            mobileMenu.classList.toggle('is-open');
            burgerBtn.classList.toggle('burger-button--active');

            if (mobileMenu.classList.contains('is-open')) {
                document.body.style.overflow = 'hidden';
            } else {
                document.body.style.overflow = '';
            }

        });

        menuLinks.forEach(link => {

            link.addEventListener('click', () => {

                mobileMenu.classList.remove('is-open');
                burgerBtn.classList.remove('burger-button--active');
                document.body.style.overflow = '';

            });

        });

    }

</script>
