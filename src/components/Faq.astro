---

---

<section class="faq">

    <div class="container">

        <div class="faq__heading">

            <h3 class="faq__title">
                Pertanyaan Umum
            </h3>

        </div>

        <div class="faq__list">

            <!-- item 01 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Siapa yang dapat berpartisipasi?
                    </span>

                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Desainer furnitur dan interior Indonesia, arsitek, mahasiswa desain, studio desain kecil, serta perajin independen lokal dapat mengikuti kompetisi ini.
                    </p>

                </div>

            </article>

            <!-- item 02 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Apakah saya dapat mengirim lebih dari satu koleksi?
                    </span>

                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Tidak. Setiap peserta hanya dapat mengirimkan satu koleksi. Koleksi harus terdiri dari 3 hingga 5 produk furnitur dan sepenuhnya berada dalam kategori Indoor atau Outdoor.
                    </p>

                </div>

            </article>

            <!-- item 03 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Apakah mahasiswa dapat mendaftar?
                    </span>

                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Tentu saja. Mahasiswa desain sangat dipersilakan untuk berpartisipasi dalam kompetisi ini.
                    </p>

                </div>

            </article>

            <!-- item 04 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Siapa yang memiliki hak kekayaan intelektual atas desain?
                    </span>

                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Hak desain sepenuhnya tetap menjadi milik Anda. Woodara hanya memperoleh hak eksklusif untuk produksi komersial dan penjualan global bagi 5 koleksi pemenang teratas berdasarkan kontrak kerja sama dan skema royalti yang disepakati.
                    </p>

                </div>

            </article>

            <!-- item 05 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Bagaimana pemenang dipilih?
                    </span>

                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Proses seleksi dilakukan dalam dua tahap. Pertama, karya akan melalui verifikasi dan voting publik di situs web kami untuk menentukan 20 finalis terbaik. Selanjutnya, dewan juri yang terdiri dari akademisi, desainer, dan profesional industri akan melakukan evaluasi dan memilih 5 pemenang utama.
                    </p>

                </div>

            </article>

            <!-- item 06 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Apa yang terjadi setelah memenangkan kompetisi?
                    </span>
                
                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Pemenang akan menandatangani kontrak resmi terkait produksi dan royalti. Tim Woodara akan membantu menyempurnakan aspek teknis produk, mengoordinasikan produksi di pabrik-pabrik mitra bersertifikasi, serta meluncurkan koleksi ke pasar internasional dengan tetap mencantumkan nama desainer sebagai pencipta karya.
                    </p>

                </div>

            </article>

            <!-- item 07 -->
            <article class="faq__item">

                <button class="faq__question">

                    <span class="faq__question-text">
                        Apakah saya wajib menyediakan file CAD, atau cukup 3D render dan gambar ukuran dalam format PDF?
                    </span>
                
                    <span class="faq__icon"></span>

                </button>

                <div class="faq__answer">

                    <p class="faq__answer-text">
                        Pada tahap pertama, peserta hanya perlu mengirimkan 3D render berkualitas tinggi serta gambar dimensi dasar dalam format PDF. Jika Anda lolos ke tahap semifinal, tim teknis kami akan membantu menyempurnakan aspek konstruksi produk. File CAD final hanya diperlukan pada tahap persiapan produksi.
                    </p>

                </div>

            </article>

        </div>

    </div>

</section>

<style>

    .faq {
        background-color: #111;
        padding: 8rem 0;
    }

    .faq .container {
        width: 100%;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .faq__heading {
        margin-bottom: 6rem;
    }

    .faq__title {
        color: #FFFFFF;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
    }

    .faq__list {
        border-top: 0.1rem solid rgba(255, 255, 255, 0.15);
    }

    .faq__item {
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.15);
    }

    .faq__question {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        padding: 3rem 0;
        background: transparent;
        border: none;
        cursor: pointer;
        text-align: left;
    }

    .faq__question-text {
        color: #FFFFFF;
        font-size: 2rem;
        font-weight: 300;

    }

    .faq__icon {
        position: relative;
        width: 2.4rem;
        height: 2.4rem;
        flex-shrink: 0;
    }

    .faq__icon::before,
    .faq__icon::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        background-color: #FFFFFF;
        transform: translate(-50%, -50%);
    }

    .faq__icon::before {
        width: 2rem;
        height: 0.1rem;
    }

    .faq__icon::after {
        width: 0.1rem;
        height: 2rem;
        transition: transform 0.3s ease;
    }

    .faq__item.active .faq__icon::after {
        transform: translate(-50%, -50%) scaleY(0);
    }

    .faq__answer {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        padding: 0;
        transition:
            max-height 0.35s ease,
            opacity 0.35s ease,
            padding 0.35s ease;
    }

    .faq__item.active .faq__answer {
        max-height: 30rem;
        opacity: 1;
        padding-bottom: 3rem;
    }

    .faq__answer-text {
        max-width: 100rem;
        color: #888888;
        font-size: 1.6rem;
        line-height: 1.7;
    }

    @media (max-width: 768px) {

        .faq {
            padding: 5rem 0;
        }

        .faq__heading {
            margin-bottom: 3.5rem;
        }

        .faq__title {
            font-size: 3.2rem;
            line-height: 1.2;
        }

        .faq__question {
            padding: 2rem 0;
            gap: 1.6rem;
        }

        .faq__question-text {
            font-size: 1.8rem;
            line-height: 1.4;
        }

        .faq__icon {
            width: 2rem;
            height: 2rem;
        }

        .faq__icon::before {
            width: 1.6rem;
        }

        .faq__icon::after {
            height: 1.6rem;
        }

        .faq__answer {
            padding-bottom: 2.4rem;
        }

        .faq__answer-text {
            font-size: 1.4rem;
            line-height: 1.6;
        }

         .faq__item.active .faq__answer {
            padding-bottom: 2.4rem;
        }
    }
        
</style>

<script>

    const faqItems = document.querySelectorAll('.faq__item');

    faqItems.forEach(item => {

        const button = item.querySelector('.faq__question');

        if (!button) return;

        button.addEventListener('click', () => {

            const isActive = item.classList.contains('active');

            faqItems.forEach(el => {
                el.classList.remove('active');
            });

            if (!isActive) {
                item.classList.add('active');
            }

        });

    });

</script>