<style>

    .faq {
        background-color: #111;
        padding: 8rem 0;
    }

    .faq .container {
        width: 100%;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .faq__heading {
        margin-bottom: 6rem;
    }

    .faq__title {
        color: #FFFFFF;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
    }

    .faq__list {
        border-top: 0.1rem solid rgba(255, 255, 255, 0.15);
    }

    .faq__item {
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.15);
    }

    .faq__question {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        padding: 3rem 0;
        background: transparent;
        border: none;
        cursor: pointer;
        text-align: left;
    }

    .faq__question-text {
        color: #FFFFFF;
        font-size: 2rem;
        font-weight: 300;

    }

    .faq__icon {
        position: relative;
        width: 2.4rem;
        height: 2.4rem;
        flex-shrink: 0;
    }

    .faq__icon::before,
    .faq__icon::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        background-color: #FFFFFF;
        transform: translate(-50%, -50%);
    }

    .faq__icon::before {
        width: 2rem;
        height: 0.1rem;
    }

    .faq__icon::after {
        width: 0.1rem;
        height: 2rem;
        transition: transform 0.3s ease;
    }

    .faq__item.active .faq__icon::after {
        transform: translate(-50%, -50%) scaleY(0);
    }

    .faq__answer {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        padding: 0;
        transition:
            max-height 0.35s ease,
            opacity 0.25s ease,
            padding 0.35s ease;
    }

    .faq__item.active .faq__answer {
        max-height: 30rem;
        opacity: 1;
        padding-bottom: 3rem;
    }

    .faq__answer-text {
        max-width: 100rem;
        color: #888888;
        font-size: 1.6rem;
        line-height: 1.7;
    }

    .faq__item.active .faq__answer {
        display: block;
    }

    .faq__item.active .faq__icon::after {
        display: none;
    }

    @media (max-width: 768px) {

        .faq {
            padding: 5rem 0;
        }

        .faq__heading {
            margin-bottom: 3.5rem;
        }

        .faq__title {
            font-size: 3.2rem;
            line-height: 1.2;
        }

        .faq__question {
            padding: 2rem 0;
            gap: 1.6rem;
        }

        .faq__question-text {
            font-size: 1.8rem;
            line-height: 1.4;
        }

        .faq__icon {
            width: 2rem;
            height: 2rem;
        }

        .faq__icon::before {
            width: 1.6rem;
        }

        .faq__icon::after {
            height: 1.6rem;
        }

        .faq__answer {
            padding-bottom: 2.4rem;
        }

        .faq__answer-text {
            font-size: 1.4rem;
            line-height: 1.6;
        }

         .faq__item.active .faq__answer {
            padding-bottom: 2.4rem;
        }
    }
        
</style>

<script>

    const faqItems = document.querySelectorAll('.faq__item');

    faqItems.forEach(item => {

        const button = item.querySelector('.faq__question');

        if (!button) return;

        button.addEventListener('click', () => {

            const isActive = item.classList.contains('active');

            faqItems.forEach(el => {
                el.classList.remove('active');
            });

            if (!isActive) {
                item.classList.add('active');
            }

        });

    });

</script>