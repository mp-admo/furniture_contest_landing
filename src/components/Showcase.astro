<style>

    .showcase {
        background-color: #111;
    }

    .container {
        width: 100%;
        max-width: 140rem; 
        padding: 0 2rem;
        margin: 0 auto;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        border-right: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__countdown-wrapper {
        background-color: #171717;
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__countdown {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2.8rem 0;
    }

    .showcase__countdown-text { 
        color: #888888;
        font-size: 1.1rem;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
    }

    .showcase__timer {
        display: flex;
    }

    .showcase__time-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 12rem;
        padding: 0 3.6rem;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        gap: 0.6rem;
    }

    .showcase__time-value {
        color: #FFFFFF;
        font-size: 5.8rem;
        font-weight: 200;
        line-height: 1;
        letter-spacing: -0.04rem;
        font-variant-numeric: tabular-nums;
    }

    .showcase__time-label {
        color: #888;
        font-size: 0.9rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: 0.2rem;
        text-transform: uppercase;  
    }

    .showcase__metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
    }

    .showcase__metric {
        display: flex;
        flex-direction: column;
        padding: 4.8rem;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        gap: 0.8rem;
    }

    .showcase__metric:first-child {
        border-left: none;
    }

    .showcase__metric-value {
        color: #FFFFFF;
        font-weight: 200;
        line-height: 1;
        letter-spacing: -0.04em;
        font-variant-numeric: tabular-nums;
    }

    .showcase__metric-label {
        color: #888888;
        font-size: 1.1rem;
        letter-spacing: 0.2rem;
        text-transform: uppercase; 
    }

    .showcase__ticker-wrapper {
        background-color: #171717;
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
        border-top: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__ticker-wrapper .container {
        padding: 0;
    }

    .showcase__ticker {
        overflow: hidden;
    }

    .showcase__ticker-track {
        display: flex;
        align-items: center;
        width: max-content;
        padding: 1.6rem 0;
    }

    .showcase__ticker-item {
        color: #888888;
        font-size: 1rem;
        letter-spacing: 0.26rem;
        text-transform: uppercase;
        padding: 0 4rem;
        border-right: 0.1rem solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
    }

    .showcase__ticker-item:first-child {
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__ticker-track {
        animation: ticker-scroll 40s linear infinite;
    }

    @keyframes ticker-scroll {

        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }

    }

    @media (max-width: 768px) {

        .showcase__countdown {
            flex-direction: column;
            align-items: flex-start;
            padding: 4rem 0;
            gap: 3rem; 
        }

        .showcase__countdown {
            align-items: center;
        }

        .showcase__timer {
            width: 100%;
            justify-content: space-between;
        }

        .showcase__time-unit {
            min-width: unset;
            flex: 1;
            padding: 0 1rem;
            gap: 0.6rem;
        }

        .showcase__time-unit:first-child {
            border-left: none;
        }

        .showcase__time-value {
            font-size: 3.6rem;
        }

        .showcase__time-label {
            font-size: 0.8rem;
        }


        .showcase__metrics {
            grid-template-columns: repeat(2, 1fr);
            margin-left: -2rem;
            margin-right: -2rem;
        }

        .showcase__metric {
            padding: 4rem 2rem; 
            border-left: none; 
            border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
        }

        .showcase__metric:nth-child(even) {
            border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        }

        .showcase__metric:nth-last-child(-n+2) {
            border-bottom: none;
        }

        .showcase__metric-value {
            font-size: 3.6rem; 
        }

        .showcase__metric-label {
            font-size: 1rem;
            line-height: 1.3;
        }
    }
    
</style>

<script>

    const targetDate = new Date('2026-06-15T23:59:59+08:00');

    const daysEl = document.getElementById('days') as HTMLElement;
    const hoursEl = document.getElementById('hours') as HTMLElement;
    const minutesEl = document.getElementById('minutes') as HTMLElement;
    const secondsEl = document.getElementById('seconds') as HTMLElement;

    function updateCountdown(): void {

        const now = new Date();
        const distance = targetDate.getTime() - now.getTime();

        if (distance <= 0) {

            daysEl.textContent = '00';
            hoursEl.textContent = '00';
            minutesEl.textContent = '00';
            secondsEl.textContent = '00';

            return;
        }

        const days = Math.floor(
            distance / (1000 * 60 * 60 * 24)
        );

        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24))
            / (1000 * 60 * 60)
        );

        const minutes = Math.floor(
            (distance % (1000 * 60 * 60))
            / (1000 * 60)
        );

        const seconds = Math.floor(
            (distance % (1000 * 60))
            / 1000
        );

        daysEl.textContent = String(days).padStart(2, '0');
        hoursEl.textContent = String(hours).padStart(2, '0');
        minutesEl.textContent = String(minutes).padStart(2, '0');
        secondsEl.textContent = String(seconds).padStart(2, '0');

    }

    updateCountdown();

    setInterval(updateCountdown, 1000);

</script>