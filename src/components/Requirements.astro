<section class="requirements">

    <div class="container">


        <!-- heading -->
        <div class="requirements__heading">

            <span class="requirements__subtitle">
                Cara Berpartisipasi
            </span>

            <h3 class="requirements__main-title">

                Apa yang Kami

                <span class="requirements__main-title-italic">
                    Cari dari Anda
                </span>

            </h3>

        </div>


        <!-- content -->
        <div class="requirements__content">


            <!-- left side -->
            <div class="requirements__visual">

                <model-viewer
                    src="/wooden_chair.glb"
                    camera-controls
                    class="requirements__model">
                </model-viewer>

            </div>


            <!-- accordion -->
            <div class="requirements__accordion">


                <!-- item -->
                <article class="requirements__item is-active">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            01
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <!-- title -->
                            <h5 class="requirements__title">
                                Sketsa Konsep
                            </h5>

                            <!-- content -->
                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Tuangkan visi awal Anda ke dalam sketsa yang kuat dan ekspresif. Ini adalah jiwa dari desain Anda sebelum menjadi kenyataan.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>



                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <span class="requirements__number">
                            02
                        </span>

                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Gambar Desain
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Dokumen teknis yang akurat dan terperinci membuktikan bahwa desain Anda bukan sekadar mimpi — melainkan solusi yang bisa diproduksi.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>



                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <span class="requirements__number">
                            03
                        </span>

                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                3D Render Berkualitas Tinggi
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Presentasikan karya Anda dalam render tiga dimensi yang matang dan siap menaklukkan standar estetika pasar internasional.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>



                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <span class="requirements__number">
                            04
                        </span>

                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Kategori: Indoor & Outdoor
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Kompetisi terbuka untuk semua kategori mebel — dari ruang tamu hingga taman, dari area kerja hingga ruang santai luar ruangan.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>

            </div>

        </div>

    </div>

</section>

<style>

    .requirements {
        background-color: #f9f9f9;
        padding: 8rem 0;
    }

    .requirements .container {
        width: 100%;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .requirements__heading {
        max-width: 62rem;
        margin-bottom: 6rem;
    }

    .requirements__subtitle {
        display: inline-flex;
        align-items: center;
        color: #111; 
        font-size: 1.2rem; 
        font-weight: 400;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
        margin-bottom: 3.2rem;
    }

    .requirements__subtitle::before {
        content: ""; 
        display: inline-block;
        width: 0.6rem; 
        height: 0.6rem; 
        background-color: #111;
        border-radius: 50%; 
        margin-right: 1rem; 
    }

    .requirements__main-title {
        display: flex;
        flex-direction: column;
        color: #111;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
    }


    .requirements__main-title-italic {
        font-style: italic;
        font-weight: 300;
        color: #888;
    }


    .requirements__content {
        display: grid;
        grid-template-columns: 45% 1fr;
        gap: 8rem;
        align-items: start;
    }

    .requirements__visual {
        position: sticky;
        top: 4rem;
        aspect-ratio: 1 / 1;
        background: #f2f1ee;
        background-image:
        linear-gradient(rgba(0,0,0,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,.04) 1px, transparent 1px);
        background-size: 4rem 4rem;
    }

    .requirements__model {
        width: 100%;
        height: 100%;
    }

    .requirements__accordion {
        display: flex;
        flex-direction: column;
    }

    .requirements__item {
        position: relative;
        padding: 5rem 0 3.4rem;
        border-bottom: 1px solid rgba(90, 90, 90, 0.2);
    }

  .requirements__item:first-child {
        padding-top: 0;
    }

    .requirements__wrapper {
        display: flex;
        align-items: flex-start;
        gap: 2rem;
    }

    .requirements__number {
        width: 6rem;
        flex-shrink: 0;
        color: #888;
        font-size: 1.2rem; 
        font-weight: 400;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
    }

    .requirements__info {
        flex: 1;
    }

    .requirements__title {
        color: #111;
        letter-spacing: -0.02em;
        margin-bottom: 1.6rem;
        cursor: pointer;
    }

    .requirements__content-box {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s ease;
    }

    .requirements__text {
        color: #888888;
        font-size: 1.6rem;
        line-height: 1.7;
        max-width: 64rem;
        padding-bottom: 1rem;
    }

    .requirements__item.is-active .requirements__content-box {
        max-height: 20rem;
    }

    @media (max-width: 768px) {
        .requirements {
            padding: 5rem 0;
        }

        .requirements__heading {
            margin-bottom: 3.5rem;
            max-width: 100%;
        }

        .requirements__subtitle {
            margin-bottom: 2rem;
        }

        .requirements__main-title {
            font-size: 3.2rem; 
            line-height: 1.2;
        }

    
        .requirements__content {
            grid-template-columns: 1fr;
            gap: 3.5rem; /* Убираем десктопный зазор между колонками */
        }

        .requirements__visual {
            position: static;
            width: 100%;
        }

        .requirements__accordion {
            border-top: 1px solid rgba(255, 255, 255, 0.1); 
        }

        .requirements__item {
            padding: 2.4rem 0 1rem; 
        }

        .requirements__wrapper {
            gap: 1.5rem;
        }

        .requirements__number {
            width: 4rem; 
            font-size: 1.1rem;
        }

        .requirements__title {
            font-size: 1.6rem;
            margin-bottom: 1rem;
        }

        .requirements__text {
            font-size: 1.4rem; 
            max-width: 100%;
        }
    }

</style>

<script>

    const accordionItems = document.querySelectorAll('.requirements__item');

    accordionItems.forEach(item => {

        item.addEventListener('click', () => {

            // закрываем все item
            accordionItems.forEach(otherItem => {
                otherItem.classList.remove('is-active');
            });

            // открываем текущий
            item.classList.add('is-active');

        });

    });

</script>

<script
    type="module"
    src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js">
</script>