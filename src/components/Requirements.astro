<section class="requirements">

    <div class="container">

        <!-- heading -->
        <div class="requirements__heading">

            <!-- heading-left-->
            <div class="requirements__heading-left">

                <span class="requirements__subtitle">
                    Cara Berpartisipasi
                </span>

                <h3 class="requirements__main-title">

                    Apa yang Kami

                    <span class="requirements__main-title-italic">
                        Cari dari Anda
                    </span>

                </h3>

            </div>

            <div class="requirements__heading-right">

                <p class="requirements__description">
                    Kompetisi ini terbuka bagi desainer furnitur Indonesia, desainer interior, arsitek, mahasiswa desain, perajin independen, dan studio kreatif kecil. Peserta diharapkan memiliki kemampuan dasar pemodelan 3D serta mampu menyiapkan presentasi profesional untuk koleksi yang diajukan.
                </p>

                <div class="requirements__downloads">

                    <a 
