    }

    .requirements__downloads {
        display: flex;
        gap: 1.6rem;
        margin-top: 3.2rem;
    }

    .requirements__download-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24rem;
        height: 6rem;
        background: #d62828;
        border-radius: 1rem;
        color: #fff;
        text-decoration: none;
        text-transform: uppercase;
