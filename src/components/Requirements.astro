                    class="requirements__model">
                </model-viewer>

            </div>


            <!-- accordion -->
            <div class="requirements__accordion">

                <!-- item -->
                <article class="requirements__item is-active">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            01
                        </span>

                        <!-- info -->
                        <div class="requirements__info">
    
                            <h5 class="requirements__title">
                                Manifesto desain
                            </h5>
                            
                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Jelaskan inspirasi, filosofi, dan ide utama di balik koleksi Anda. Tunjukkan bagaimana konsep tersebut diterjemahkan ke dalam desain produk.
                                </p>
                            
                            </div>
                            
                        </div>

                    </div>

                </article>

                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            02
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Visualisasi 3D
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Sertakan render 3D berkualitas tinggi untuk setiap produk. Tampilkan minimal tiga sudut pandang yang memperlihatkan bentuk, proporsi, dan detail utama.
                                </p>
                            
                            </div>

                        </div>

                    </div>

                </article>

                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            03
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Gambar
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Lampirkan gambar produk dengan dimensi utama, proporsi yang jelas, serta tampilan yang membantu memahami bentuk dan konstruksi produk.
                                </p>
                            
                            </div>

                        </div>

                    </div>

                </article>


                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            04
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Spesifikasi material
                            </h5>

                            <div class="requirements__content-box">

                            <p class="requirements__text">
                                Jelaskan material yang digunakan dalam setiap produk, termasuk kombinasi material, finishing, dan alasan pemilihannya.
                            </p>

                            </div>

                        </div>

                    </div>

                </article>

                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            05
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Publikasi media sosial
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Ikuti akun media sosial kami dan pantau informasi terbaru, pengumuman, serta perkembangan kompetisi.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>

                <!-- item -->
                <article class="requirements__item">

                    <div class="requirements__wrapper">

                        <!-- number -->
                        <span class="requirements__number">
                            06
                        </span>

                        <!-- info -->
                        <div class="requirements__info">

                            <h5 class="requirements__title">
                                Catatan penting
                            </h5>

                            <div class="requirements__content-box">

                                <p class="requirements__text">
                                    Pastikan seluruh dokumen dan materi telah dilengkapi sebelum pengiriman. Pengajuan yang tidak lengkap tidak akan dipertimbangkan dalam proses penilaian.
                                </p>

                            </div>

                        </div>

                    </div>

                </article>


            </div>

        </div>

    </div>

</section>

<style>

